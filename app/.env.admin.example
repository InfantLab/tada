# Admin CLI credentials (bun run admin ...)
# Copy this file to .env.admin and fill in real values. .env.admin is gitignored.
#
# Usage:
#   bun --env-file=.env.admin run admin users list --search=caspar
#   bun --env-file=.env.admin run admin modules set <userId> ourmoji=true

TADA_ADMIN_URL=https://tada.living
TADA_ADMIN_USERNAME=your-prod-username
TADA_ADMIN_PASSWORD=your-prod-password
