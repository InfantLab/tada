{
  "name": "tada",
  "version": "0.7.3",
  "private": true,
  "type": "module",
  "description": "Personal lifelogger - Track Activities, Discover Achievements",
  "scripts": {
    "dev": "DATABASE_URL=file:../data/db.sqlite nuxt dev",
    "build": "nuxt build",
    "build:docker": "node scripts/capture-git-info.js && NUXT_TYPESCRIPT_TYPECHECK=false nuxt build",
    "build:capacitor": "node scripts/capture-git-info.js && NUXT_TYPESCRIPT_TYPECHECK=false NUXT_PUBLIC_API_BASE_URL=https://tada.living nuxt generate",
    "android:sync": "bun run build:capacitor && bunx cap sync android",
    "android:dev": "node scripts/android-dev.js",
    "android:open": "npx cap open android",
    "android:run": "npx cap run android",
    "android:assets": "npx @capacitor/assets generate --android --assetPath assets/capacitor --iconBackgroundColor #10b981 --iconBackgroundColorDark #10b981 --splashBackgroundColor #10b981 --splashBackgroundColorDark #0c8e6f",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "DATABASE_URL=file:../data/db.sqlite bun run migrate.js",
    "db:studio": "DATABASE_URL=file:../data/db.sqlite drizzle-kit studio",
    "admin": "bun run scripts/admin.ts"
  },
  "dependencies": {
    "@capacitor/push-notifications": "^8.1.1",
    "@libsql/client": "^0.17.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.38.3",
    "emoji-picker-element": "^1.26.0",
    "nanoid": "^5.1.6",
    "nodemailer": "^7.0.12",
    "papaparse": "^5.5.2",
    "stripe": "^20.4.1",
    "vue-virtual-scroller": "^1.1.2",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/app": "^8.1.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@capacitor/local-notifications": "^8.1.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.1.14",
    "@types/nodemailer": "^7.0.5",
    "@types/papaparse": "^5.3.15",
    "@types/web-push": "^3.6.4",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^3.0.0",
    "@vue/test-utils": "^2.4.6",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "happy-dom": "^16.0.0",
    "nuxt": "^4.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0",
    "vue-tsc": "^3.2.2"
  }
}
