{
  "name": "tada",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "description": "Personal lifelogger - Track Activities, Discover Achievements",
  "scripts": {
    "dev": "DATABASE_URL=file:../data/db.sqlite nuxt dev",
    "build": "nuxt build",
    "build:docker": "node scripts/capture-git-info.js && NUXT_TYPESCRIPT_TYPECHECK=false nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "DATABASE_URL=file:../data/db.sqlite drizzle-kit migrate",
    "db:studio": "DATABASE_URL=file:../data/db.sqlite drizzle-kit studio"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.38.3",
    "emoji-picker-element": "^1.26.0",
    "nanoid": "^5.1.6",
    "nodemailer": "^7.0.12",
    "papaparse": "^5.5.2",
    "stripe": "^20.4.1",
    "vue-virtual-scroller": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.1.14",
    "@types/nodemailer": "^7.0.5",
    "@types/papaparse": "^5.3.15",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^3.0.0",
    "@vue/test-utils": "^2.4.6",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "happy-dom": "^16.0.0",
    "nuxt": "^4.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0",
    "vue-tsc": "^3.2.2"
  }
}
